<category>
    <pattern>HOW CAN I REACH THE COLLEGE</pattern>
    <template>
        You can reach VCET by city bus, taxi, auto-rickshaw, or your own vehicle from Madurai city.
    </template>
</category>

<category>
    <pattern>WHERE IS THE COLLEGE OFFICE</pattern>
    <template>
        The Administrative Office is located inside the main academic block. Please contact the reception for assistance.
    </template>
</category>

