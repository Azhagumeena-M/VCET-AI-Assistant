<category>
    <pattern>WHERE IS THE COLLEGE LOCATED</pattern>
    <template>
        Velammal College of Engineering and Technology (VCET) is located at Viraganoor, Madurai, Tamil Nadu, India.
    </template>
</category>

<category>
    <pattern>WHERE IS VCET LOCATED</pattern>
    <template>
        VCET is located at Viraganoor, Madurai, Tamil Nadu.
    </template>
</category>

<category>
